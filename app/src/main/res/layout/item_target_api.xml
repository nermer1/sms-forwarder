<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#F5F5F5"
    app:cardCornerRadius="10dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔌 API URL 전달"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:strokeColor="#CCCCCC"
                app:strokeWidth="1dp">
                <Spinner
                    android:id="@+id/spinnerPreset"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:spinnerMode="dropdown"
                    android:backgroundTint="#666666" />
            </com.google.android.material.card.MaterialCardView>

            <ImageButton
                android:id="@+id/btnRemoveTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#D32F2F" />
        </LinearLayout>

        <EditText
            android:id="@+id/etTargetUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API Endpoint URL"
            android:inputType="textUri"
            android:textSize="14sp" />

        <!-- Headers 섹션 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Headers"
            android:textSize="12sp"
            android:textStyle="bold" />
        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
        <Button
            android:id="@+id/btnAddHeader"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Header 추가"
            android:textSize="11sp" />

        <!-- Body 섹션 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Request Body (JSON)"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사용 가능: {{sender}}, {{content}}, {{title}}, {{date}}"
            android:textSize="10sp"
            android:textColor="#666666" />
        <LinearLayout
            android:id="@+id/bodyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
        <Button
            android:id="@+id/btnAddBody"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Body 필드 추가"
            android:textSize="11sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>